@model List<PuestoElectivoViewModel>
@{
    ViewData["Title"] = "Puestos Electivos";
    bool hayEleccionActiva = ViewBag.HayEleccionActiva ?? false;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-briefcase"></i> Puestos Electivos</h2>
    @if (!hayEleccionActiva)
    {
        <a asp-action="Create" class="btn btn-primary"><i class="bi bi-plus-circle"></i> Nuevo Puesto</a>
    }
</div>

@if (hayEleccionActiva)
{
    <div class="alert alert-warning"><i class="bi bi-lock"></i> Acciones bloqueadas mientras hay una elección activa.</div>
}

<div class="card shadow">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-primary">
                    <tr>
                        <th>Nombre</th>
                        <th>Descripción</th>
                        <th>Estado</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.Nombre</td>
                            <td>@item.Descripcion</td>
                            <td>
                                <span class="badge @(item.Activo ? "bg-success" : "bg-danger")">
                                    @(item.Activo ? "Activo" : "Inactivo")
                                </span>
                            </td>
                            <td>
                                @if (!hayEleccionActiva)
                                {
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <form asp-action="CambiarEstado" method="post" class="d-inline">
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <button type="submit" class="btn btn-sm @(item.Activo ? "btn-secondary" : "btn-success")">
                                            <i class="bi @(item.Activo ? "bi-toggle-off" : "bi-toggle-on")"></i>
                                        </button>
                                    </form>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>