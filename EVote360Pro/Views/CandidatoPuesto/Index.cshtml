@model List<CandidatoPuestoViewModel>
@{
    ViewData["Title"] = "Asignación de Candidatos a Puestos";
    Layout = "_LayoutDirigent";
    bool hayEleccionActiva = ViewBag.HayEleccionActiva ?? false;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-person-lines-fill"></i> Asignar Candidato a Puesto</h2>
    @if (!hayEleccionActiva)
    {
        <a asp-action="Create" class="btn btn-primary"><i class="bi bi-plus-circle"></i> Nueva Asignación</a>
    }
</div>

@if (hayEleccionActiva)
{
    <div class="alert alert-warning"><i class="bi bi-lock"></i> Acciones bloqueadas mientras hay una elección activa.</div>
}

<div class="card shadow">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-primary">
                    <tr>
                        <th>Candidato</th>
                        <th>Puesto Electivo</th>
                        <th>Partido</th>
                        <th>Tipo</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.NombreCandidato</td>
                            <td>@item.NombrePuesto</td>
                            <td>@item.NombrePartido</td>
                            <td>
                                <span class="badge @(item.EsCandidatoAliado ? "bg-info" : "bg-primary")">
                                    @(item.EsCandidatoAliado ? "Aliado" : "Propio")
                                </span>
                            </td>
                            <td>
                                @if (!hayEleccionActiva)
                                {
                                    <form asp-action="Delete" method="post" class="d-inline">
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <button type="submit" class="btn btn-sm btn-danger">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>