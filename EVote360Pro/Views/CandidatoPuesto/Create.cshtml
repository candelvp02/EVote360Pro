@model SaveCandidatoPuestoViewModel
@{
    ViewData["Title"] = "Nueva Asignación";
    Layout = "_LayoutDirigent";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-person-lines-fill"></i> Nueva Asignación</h2>
    <a asp-action="Index" class="btn btn-secondary"><i class="bi bi-arrow-left"></i> Volver</a>
</div>

<div class="card shadow">
    <div class="card-body">
        <form asp-action="Create" method="post">
            <input type="hidden" asp-for="PartidoPoliticoId" />
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="CandidatoId" class="form-label">Candidato</label>
                    <select asp-for="CandidatoId" class="form-select"
                            asp-items="@(new SelectList(ViewBag.Candidatos, "Id", "Nombre"))">
                        <option value="">-- Seleccione un candidato --</option>
                    </select>
                    <span asp-validation-for="CandidatoId" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="PuestoElectivoId" class="form-label">Puesto Electivo</label>
                    <select asp-for="PuestoElectivoId" class="form-select"
                            asp-items="@(new SelectList(ViewBag.Puestos, "Id", "Nombre"))">
                        <option value="">-- Seleccione un puesto --</option>
                    </select>
                    <span asp-validation-for="PuestoElectivoId" class="text-danger small"></span>
                </div>
            </div>
            <div class="mt-4">
                <button type="submit" class="btn btn-primary"><i class="bi bi-save"></i> Guardar</button>
                <a asp-action="Index" class="btn btn-secondary ms-2">Cancelar</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}