@model List<DirigentePoliticoViewModel>
@{
    ViewData["Title"] = "Dirigentes Políticos";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-person-badge"></i> Dirigentes Políticos</h2>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-circle"></i> Nueva Asignación
    </a>
</div>

<div class="card shadow">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-primary">
                    <tr>
                        <th>Usuario</th>
                        <th>Nombre Completo</th>
                        <th>Partido</th>
                        <th>Siglas</th>
                        <th>Estado</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.NombreUsuario</td>
                            <td>@item.NombreCompletoUsuario</td>
                            <td>@item.NombrePartido</td>
                            <td><span class="badge bg-primary">@item.SiglasPartido</span></td>
                            <td>
                                <span class="badge @(item.Activo ? "bg-success" : "bg-danger")">
                                    @(item.Activo ? "Activo" : "Inactivo")
                                </span>
                            </td>
                            <td>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">
                                    <i class="bi bi-trash"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>