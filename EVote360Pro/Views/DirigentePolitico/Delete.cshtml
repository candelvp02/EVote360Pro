@model DeleteDirigentePoliticoViewModel
@{
    ViewData["Title"] = "Eliminar Asignación";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-trash"></i> Eliminar Asignación</h2>
    <a asp-action="Index" class="btn btn-secondary"><i class="bi bi-arrow-left"></i> Volver</a>
</div>

<div class="card shadow border-danger">
    <div class="card-body">
        <div class="alert alert-danger">
            <i class="bi bi-exclamation-triangle"></i> ¿Está seguro que desea eliminar esta asignación?
        </div>
        <dl class="row">
            <dt class="col-sm-3">Usuario</dt>
            <dd class="col-sm-9">@Model.NombreUsuario</dd>
            <dt class="col-sm-3">Partido</dt>
            <dd class="col-sm-9">@Model.NombrePartido</dd>
        </dl>
        <form asp-action="Delete" method="post">
            <input type="hidden" asp-for="Id" />
            <button type="submit" class="btn btn-danger"><i class="bi bi-trash"></i> Confirmar</button>
            <a asp-action="Index" class="btn btn-secondary ms-2">Cancelar</a>
        </form>
    </div>
</div>