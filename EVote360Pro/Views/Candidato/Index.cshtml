@model List<CandidatoViewModel>
@{
    ViewData["Title"] = "Candidatos";
    bool hayEleccionActiva = ViewBag.HayEleccionActiva ?? false;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-person-check"></i> Candidatos</h2>
    @if (!hayEleccionActiva)
    {
        <a asp-action="Create" class="btn btn-primary"><i class="bi bi-plus-circle"></i> Nuevo Candidato</a>
    }
</div>

@if (hayEleccionActiva)
{
    <div class="alert alert-warning"><i class="bi bi-lock"></i> Acciones bloqueadas mientras hay una elección activa.</div>
}

<div class="row g-4">
    @foreach (var item in Model)
    {
        <div class="col-md-3">
            <div class="card shadow h-100">
                <div class="text-center pt-3">
                    @if (!string.IsNullOrEmpty(item.FotoUrl))
                    {
                        <img src="@item.FotoUrl" alt="Foto" class="rounded-circle" style="width:80px;height:80px;object-fit:cover;" />
                    }
                    else
                    {
                        <div class="bg-light rounded-circle d-inline-flex align-items-center justify-content-center" style="width:80px;height:80px;">
                            <i class="bi bi-person fs-1 text-muted"></i>
                        </div>
                    }
                </div>
                <div class="card-body text-center">
                    <h6 class="card-title">@item.Nombre @item.Apellido</h6>
                    @if (!string.IsNullOrEmpty(item.NombrePartido))
                    {
                        <small class="text-muted">@item.NombrePartido</small>
                    }
                    <div class="mt-2">
                        <span class="badge @(item.Activo ? "bg-success" : "bg-danger")">
                            @(item.Activo ? "Activo" : "Inactivo")
                        </span>
                    </div>
                    @if (!hayEleccionActiva)
                    {
                        <div class="d-flex gap-1 justify-content-center mt-3">
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <form asp-action="CambiarEstado" method="post" class="d-inline">
                                <input type="hidden" name="id" value="@item.Id" />
                                <button type="submit" class="btn btn-sm @(item.Activo ? "btn-secondary" : "btn-success")">
                                    <i class="bi @(item.Activo ? "bi-toggle-off" : "bi-toggle-on")"></i>
                                </button>
                            </form>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">
                                <i class="bi bi-trash"></i>
                            </a>
                        </div>
                    }
                </div>
            </div>
        </div>
    }
</div>