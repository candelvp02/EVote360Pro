@model LoginViewModel
@{
    ViewData["Title"] = "Iniciar Sesión";
    Layout = "_LayoutAnonymous";
}

<div class="card shadow">
    <div class="card-body p-4">
        <h4 class="card-title text-center mb-4">Iniciar Sesión</h4>

        <form asp-action="Index" method="post">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

            <div class="mb-3">
                <label asp-for="NombreUsuario" class="form-label">Usuario</label>
                <div class="input-group">
                    <span class="input-group-text"><i class="bi bi-person"></i></span>
                    <input asp-for="NombreUsuario" class="form-control" placeholder="Ingrese su usuario" />
                </div>
                <span asp-validation-for="NombreUsuario" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Contrasena" class="form-label">Contraseña</label>
                <div class="input-group">
                    <span class="input-group-text"><i class="bi bi-lock"></i></span>
                    <input asp-for="Contrasena" class="form-control" placeholder="Ingrese su contraseña" />
                </div>
                <span asp-validation-for="Contrasena" class="text-danger small"></span>
            </div>

            <div class="d-grid mt-4">
                <button type="submit" class="btn btn-primary btn-lg">
                    <i class="bi bi-box-arrow-in-right"></i> Ingresar
                </button>
            </div>
        </form>

        <hr />
        <div class="text-center">
            <p class="text-muted mb-0">¿Es usted elector?</p>
            <a asp-controller="Votacion" asp-action="Index" class="btn btn-outline-success mt-2">
                <i class="bi bi-ballot"></i> Ir a Votar
            </a>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}