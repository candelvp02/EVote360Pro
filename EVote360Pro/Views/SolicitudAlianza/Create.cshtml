@model SaveSolicitudAlianzaViewModel
@{
    ViewData["Title"] = "Nueva Solicitud de Alianza";
    Layout = "_LayoutDirigent";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-handshake"></i> Nueva Solicitud de Alianza</h2>
    <a asp-action="Index" class="btn btn-secondary"><i class="bi bi-arrow-left"></i> Volver</a>
</div>

<div class="card shadow">
    <div class="card-body">
        <form asp-action="Create" method="post">
            <input type="hidden" asp-for="PartidoSolicitanteId" />
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="PartidoReceptorId" class="form-label">Partido Receptor</label>
                    <select asp-for="PartidoReceptorId" class="form-select"
                            asp-items="@(new SelectList(ViewBag.Partidos, "Id", "Nombre"))">
                        <option value="">-- Seleccione un partido --</option>
                    </select>
                    <span asp-validation-for="PartidoReceptorId" class="text-danger small"></span>
                </div>
            </div>
            <div class="mt-4">
                <button type="submit" class="btn btn-primary"><i class="bi bi-send"></i> Enviar Solicitud</button>
                <a asp-action="Index" class="btn btn-secondary ms-2">Cancelar</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}