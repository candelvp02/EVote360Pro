@model List<PartidoPoliticoViewModel>
@{
    ViewData["Title"] = "Partidos Políticos";
    bool hayEleccionActiva = ViewBag.HayEleccionActiva ?? false;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-flag"></i> Partidos Políticos</h2>
    @if (!hayEleccionActiva)
    {
        <a asp-action="Create" class="btn btn-primary"><i class="bi bi-plus-circle"></i> Nuevo Partido</a>
    }
</div>

@if (hayEleccionActiva)
{
    <div class="alert alert-warning"><i class="bi bi-lock"></i> Acciones bloqueadas mientras hay una elección activa.</div>
}

<div class="row g-4">
    @foreach (var item in Model)
    {
        <div class="col-md-4">
            <div class="card shadow h-100">
                <div class="card-body text-center">
                    @if (!string.IsNullOrEmpty(item.LogoUrl))
                    {
                        <img src="@item.LogoUrl" alt="Logo" class="img-fluid mb-3 rounded" style="max-height: 80px;" />
                    }
                    else
                    {
                        <div class="bg-light rounded p-3 mb-3">
                            <i class="bi bi-flag fs-1 text-muted"></i>
                        </div>
                    }
                    <h5 class="card-title">@item.Nombre</h5>
                    <span class="badge bg-primary mb-2">@item.Siglas</span>
                    @if (!string.IsNullOrEmpty(item.Descripcion))
                    {
                        <p class="card-text text-muted small">@item.Descripcion</p>
                    }
                    <span class="badge @(item.Activo ? "bg-success" : "bg-danger") d-block mb-3">
                        @(item.Activo ? "Activo" : "Inactivo")
                    </span>
                    @if (!hayEleccionActiva)
                    {
                        <div class="d-flex gap-2 justify-content-center">
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">
                                <i class="bi bi-pencil"></i> Editar
                            </a>
                            <form asp-action="CambiarEstado" method="post" class="d-inline">
                                <input type="hidden" name="id" value="@item.Id" />
                                <button type="submit" class="btn btn-sm @(item.Activo ? "btn-secondary" : "btn-success")">
                                    <i class="bi @(item.Activo ? "bi-toggle-off" : "bi-toggle-on")"></i>
                                </button>
                            </form>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">
                                <i class="bi bi-trash"></i>
                            </a>
                        </div>
                    }
                </div>
            </div>
        </div>
    }
</div>