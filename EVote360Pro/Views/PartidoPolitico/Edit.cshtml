@model SavePartidoPoliticoViewModel
@{
    ViewData["Title"] = "Editar Partido Político";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-pencil-square"></i> Editar Partido Político</h2>
    <a asp-action="Index" class="btn btn-secondary"><i class="bi bi-arrow-left"></i> Volver</a>
</div>

<div class="card shadow">
    <div class="card-body">
        <form asp-action="Edit" method="post" enctype="multipart/form-data">
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="LogoUrl" />
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
            <div class="row g-3">
                <div class="col-md-8">
                    <label asp-for="Nombre" class="form-label"></label>
                    <input asp-for="Nombre" class="form-control" />
                    <span asp-validation-for="Nombre" class="text-danger small"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="Siglas" class="form-label"></label>
                    <input asp-for="Siglas" class="form-control" />
                    <span asp-validation-for="Siglas" class="text-danger small"></span>
                </div>
                <div class="col-12">
                    <label asp-for="Descripcion" class="form-label"></label>
                    <textarea asp-for="Descripcion" class="form-control" rows="3"></textarea>
                </div>
                @if (ViewBag.CamposCriticosBloqueados == true)
                {
                    <div class="alert alert-warning">
                        El nombre, siglas y logo no pueden modificarse porque este partido participó en una elección activa o finalizada.
                    </div>
                    <input type="hidden" asp-for="Nombre" />
                    <input type="hidden" asp-for="Siglas" />
                    <input type="hidden" asp-for="LogoUrl" />
                    <div class="mb-3">
                        <label class="form-label">Nombre</label>
                        <input type="text" class="form-control" value="@Model.Nombre" disabled />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Siglas</label>
                        <input type="text" class="form-control" value="@Model.Siglas" disabled />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Logo actual</label><br />
                        <img src="@Model.LogoUrl" style="height:60px" />
                        <p class="text-muted small">No se puede cambiar el logo.</p>
                    </div>
                }
                else
                {
                    <div class="mb-3">
                        <label asp-for="Nombre" class="form-label"></label>
                        <input asp-for="Nombre" class="form-control" />
                        <span asp-validation-for="Nombre" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Siglas" class="form-label"></label>
                        <input asp-for="Siglas" class="form-control" />
                        <span asp-validation-for="Siglas" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Logo</label>
                        <input type="file" name="logoFile" class="form-control" />
                        <input type="hidden" asp-for="LogoUrl" />
                    </div>
                }
                <div class="col-md-6">
                    <label class="form-label">Estado</label>
                    <div class="form-check form-switch mt-2">
                        <input asp-for="Activo" class="form-check-input" type="checkbox" />
                        <label class="form-check-label">Activo</label>
                    </div>
                </div>
            </div>
            <div class="mt-4">
                <button type="submit" class="btn btn-primary"><i class="bi bi-save"></i> Guardar</button>
                <a asp-action="Index" class="btn btn-secondary ms-2">Cancelar</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}