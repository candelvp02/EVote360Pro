@model IniciarVotacionViewModel
@{
    ViewData["Title"] = "Iniciar Votación";
    Layout = "_LayoutAnonymous";
}

<div class="card shadow">
    <div class="card-body p-4">
        <h4 class="card-title text-center mb-4">
            <i class="bi bi-ballot"></i> Iniciar Proceso de Votación
        </h4>

        <form asp-action="Index" method="post">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

            <div class="mb-3">
                <label asp-for="NumeroDocumento" class="form-label">Número de Documento</label>
                <div class="input-group">
                    <span class="input-group-text"><i class="bi bi-person-vcard"></i></span>
                    <input asp-for="NumeroDocumento" class="form-control form-control-lg"
                           placeholder="Ingrese su número de documento" />
                </div>
                <span asp-validation-for="NumeroDocumento" class="text-danger small"></span>
                <small class="text-muted">El número de documento debe ingresarse como texto (ej: 40212345678)</small>
            </div>

            <div class="d-grid mt-4">
                <button type="submit" class="btn btn-success btn-lg">
                    <i class="bi bi-arrow-right-circle"></i> Continuar
                </button>
            </div>
        </form>

        <hr />
        <div class="text-center">
            <a asp-controller="Login" asp-action="Index" class="btn btn-outline-primary">
                <i class="bi bi-person-gear"></i> Acceso Administrativo
            </a>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}