@model EVote360Pro.Core.Application.ViewModels.Voto.IniciarVotacionViewModel

<form method="post" enctype="multipart/form-data">
    @Html.AntiForgeryToken()

    <div class="mb-3">
        <label asp-for="NumeroDocumento" class="form-label">Número de documento</label>
        <input asp-for="NumeroDocumento" class="form-control" placeholder="000-0000000-0" />
        <span asp-validation-for="NumeroDocumento" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="ImagenCedula" class="form-label">Imagen de su cédula</label>
        <input asp-for="ImagenCedula" type="file" class="form-control"
               accept="image/png,image/jpeg,image/jpg,image/bmp" />
        <span asp-validation-for="ImagenCedula" class="text-danger"></span>
        <small class="text-muted">
            Suba una foto clara de su cédula de identidad. El número debe ser legible.
        </small>
    </div>

    @if (!ViewData.ModelState.IsValid)
    {
        <div class="alert alert-danger">
            @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
            {
                <p class="mb-0">@error.ErrorMessage</p>
            }
        </div>
    }

    <button type="submit" class="btn btn-primary">Continuar</button>
</form>