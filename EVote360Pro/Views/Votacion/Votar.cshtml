@model SeleccionVotoViewModel
@{
    ViewData["Title"] = "Votar";
    Layout = "_LayoutAnonymous";
}

<div class="card shadow mb-3">
    <div class="card-header bg-success text-white">
        <h5 class="mb-0"><i class="bi bi-ballot"></i> Seleccione sus candidatos — @Model.NombreCiudadano</h5>
    </div>
</div>

<form asp-action="ConfirmarVoto" method="post">
    <input type="hidden" name="ciudadanoId" value="@Model.CiudadanoId" />
    <input type="hidden" name="eleccionId" value="@Model.EleccionId" />

    @for (int i = 0; i < Model.PuestosElectivos.Count; i++)
    {
        var puesto = Model.PuestosElectivos[i];
        <div class="card shadow mb-4">
            <div class="card-header bg-primary text-white">
                <h6 class="mb-0"><i class="bi bi-briefcase"></i> @puesto.NombrePuesto</h6>
            </div>
            <div class="card-body">
                <div class="row g-3">
                    @foreach (var candidato in puesto.Candidatos)
                    {
                        <div class="col-md-3">
                            <div class="card h-100 candidato-card" style="cursor: pointer;"
                                 onclick="seleccionarCandidato(@puesto.PuestoElectivoId, @candidato.CandidatoId, this)">
                                <div class="card-body text-center p-2">
                                    @if (!string.IsNullOrEmpty(candidato.FotoUrl))
                                    {
                                        <img src="@candidato.FotoUrl" alt="Foto"
                                             class="rounded-circle mb-2" style="width:70px;height:70px;object-fit:cover;" />
                                    }
                                    else
                                    {
                                        <div class="bg-light rounded-circle d-inline-flex align-items-center justify-content-center mb-2"
                                             style="width:70px;height:70px;">
                                            <i class="bi bi-person fs-2 text-muted"></i>
                                        </div>
                                    }
                                    <p class="mb-1 fw-bold small">@candidato.NombreCompleto</p>
                                    <small class="text-muted">@candidato.NombrePartido</small>
                                    @if (!string.IsNullOrEmpty(candidato.LogoPartido))
                                    {
                                        <img src="@candidato.LogoPartido" alt="Logo"
                                             class="d-block mx-auto mt-1" style="max-height:25px;" />
                                    }
                                </div>
                            </div>
                        </div>
                    }
                    <div class="col-md-3">
                        <div class="card h-100 border-secondary candidato-card" style="cursor: pointer;"
                             onclick="seleccionarNinguno(@puesto.PuestoElectivoId, this)">
                            <div class="card-body text-center p-2 d-flex flex-column align-items-center justify-content-center">
                                <i class="bi bi-x-circle fs-1 text-secondary mb-2"></i>
                                <p class="mb-0 fw-bold">Ninguno</p>
                            </div>
                        </div>
                    </div>
                </div>
                <input type="hidden" name="selecciones[@puesto.PuestoElectivoId]" id="seleccion_@puesto.PuestoElectivoId" value="" />
            </div>
        </div>
    }

    <div class="d-grid mb-4">
        <button type="submit" class="btn btn-success btn-lg" onclick="return validarSelecciones()">
            <i class="bi bi-check-circle"></i> Confirmar Votación
        </button>
    </div>
</form>

@section Scripts {
    <script>
        function seleccionarCandidato(puestoId, candidatoId, elemento) {
            document.querySelectorAll('.candidato-card[data-puesto="' + puestoId + '"]').forEach(c => {
                c.classList.remove('border-success', 'border-3');
            });
            elemento.setAttribute('data-puesto', puestoId);
            elemento.classList.add('border-success', 'border-3');
            document.getElementById('seleccion_' + puestoId).value = candidatoId;

            document.querySelectorAll('.candidato-card').forEach(c => {
                if (c.getAttribute('data-puesto') == puestoId && c !== elemento) {
                    c.classList.remove('border-success', 'border-3');
                }
            });
        }

        function seleccionarNinguno(puestoId, elemento) {
            document.querySelectorAll('.candidato-card').forEach(c => {
                if (c.getAttribute('data-puesto') == puestoId) {
                    c.classList.remove('border-success', 'border-3');
                }
            });
            elemento.setAttribute('data-puesto', puestoId);
            elemento.classList.add('border-success', 'border-3');
            document.getElementById('seleccion_' + puestoId).value = '';
        }

        function validarSelecciones() {
            const inputs = document.querySelectorAll('input[name^="selecciones"]');
            let todosSeleccionados = true;
            inputs.forEach(input => {
                if (input.value === '' && !input.closest('.card-body').querySelector('.border-success')) {
                    todosSeleccionados = false;
                }
            });
            if (!todosSeleccionados) {
                alert('Debe seleccionar una opción para cada puesto electivo.');
                return false;
            }
            return true;
        }
    </script>
}