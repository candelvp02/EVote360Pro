@{
    ViewData["Title"] = "Votación Confirmada";
    Layout = "_LayoutAnonymous";
}

<div class="card shadow border-success">
    <div class="card-body p-5 text-center">
        <i class="bi bi-check-circle-fill text-success" style="font-size: 5rem;"></i>
        <h3 class="mt-3 text-success">¡Votación Registrada Exitosamente!</h3>
        <p class="text-muted mt-3">
            Su voto ha sido registrado. Hemos enviado un resumen a su correo electrónico.
        </p>
        <p class="text-muted small">
            Recuerde que su voto es secreto y confidencial.
        </p>
        <hr />
        <a asp-controller="Votacion" asp-action="Index" class="btn btn-success btn-lg mt-2">
            <i class="bi bi-house"></i> Volver al Inicio
        </a>
    </div>
</div>